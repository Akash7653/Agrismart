{
  "name": "agrismart-backend",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "init-db": "mysql -u root -p agrismart < database/schema.sql",
    "ml": "cd ml && uvicorn main:app --reload --port 8000",
    "dev:all": "concurrently \"npm run dev\" \"cd ml && uvicorn main:app --reload --port 8000\"",
    "start:all": "concurrently \"npm run start\" \"cd ml && uvicorn main:app --port 8000\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "agriculture",
    "farming",
    "organic",
    "marketplace",
    "consultations",
    "razorpay",
    "api"
  ],
  "author": "AgriSmart Team",
  "license": "MIT",
  "description": "AgriSmart Backend API - Natural Farming Platform",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2"
  }
}
