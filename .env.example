# AgriSmart Production Environment Configuration
# Copy this file to .env and fill in your actual values

# ==================== MONGODB ====================
MONGO_USERNAME=root
MONGO_PASSWORD=change_this_secure_password_in_production
MONGO_DATABASE=agrismart
MONGO_PORT=27017

# For MongoDB Atlas cloud:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agrismart?retryWrites=true&w=majority

# ==================== NODE.js BACKEND ====================
NODE_ENV=production
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0

# ==================== JWT AUTHENTICATION ====================
JWT_SECRET=your_very_secure_jwt_secret_key_change_this
JWT_EXPIRY=7d

# ==================== RAZORPAY PAYMENT INTEGRATION ====================
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxx
RAZORPAY_KEY_SECRET=yyyyyyyyyyyyy
RAZORPAY_WEBHOOK_SECRET=zzzzzzzzzz

# ==================== REDIS CACHE ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== ML SERVICE ====================
ML_SERVICE_URL=http://ml-service:8000
ML_SERVICE_TIMEOUT=30

# ==================== EMAIL SERVICE ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@agrismart.com

# ==================== AWS S3 (For image uploads) ====================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=agrismart-uploads
S3_URL_EXPIRY=3600

# ==================== FIREBASE (Alternative to AWS) ====================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com

# ==================== OPENWEATHERMAP API ====================
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# ==================== GOOGLE CLOUD (For TTS/STT) ====================
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_CREDENTIALS=/path/to/credentials.json

# ==================== TWILIO (For SMS notifications) ====================
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==================== FRONTEND CONFIGURATION ====================
VITE_API_URL=http://localhost:4000
VITE_ML_URL=http://localhost:8000
VITE_APP_NAME=AgriSmart
VITE_APP_VERSION=1.0.0

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FILE=/var/log/agrismart/app.log

# ==================== SECURITY ====================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
ALLOWED_HOSTS=localhost,agrismart.com,api.agrismart.com

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== DATABASE BACKUPS ====================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# ==================== SENTRY ERROR TRACKING ====================
SENTRY_DSN=your_sentry_dsn_url

# ==================== DEVELOPER OPTIONS ====================
DEBUG=false
VERBOSE_LOGGING=false
